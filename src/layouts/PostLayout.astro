---
import BaseLayout from './BaseLayout.astro';
import type { SpaceId } from '../consts';
import { spaceMeta, formatDate, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  image?: string;
  space: SpaceId;
  lang?: Lang;
  vi_url?: string;
  en_url?: string;
  tags?: string[];
}
const { title, description, date, author, image, space, lang = 'en', vi_url, en_url, tags = [] } = Astro.props;
const info = spaceMeta(space, lang);

// Counterpart in the other language for the header toggle. Fall back to the
// other language's space index when this post has no translation yet — in
// that case we ask the reader to confirm rather than redirect silently.
const hasTranslation = lang === 'vi' ? !!en_url : !!vi_url;
const altUrl =
  lang === 'vi' ? en_url ?? `/${space}/` : vi_url ?? `/vi/${space}/`;
---
<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={date}
  altUrl={altUrl}
  altConfirm={!hasTranslation}
>
  <article class="post">
    <p class="post-space"><a href={info.path}>{info.name}</a></p>
    <h1 class="post-title">{title}</h1>
    <p class="post-meta">
      <time datetime={date.toISOString()}>{formatDate(date, lang)}</time>
      {author && <> · {author}</>}
    </p>
    {tags.length > 0 && (
      <div class="tag-list">
        {tags.map((tag) => (
          <a class="tag" href={`${info.path}tags/${tag}/`}>{tag}</a>
        ))}
      </div>
    )}
    <div class="post-content">
      <slot />
    </div>
    <div class="post-comments">
      <script src="https://giscus.app/client.js"
        data-repo="vtuanjs/vtuanjs.github.io"
        data-repo-id="R_kgDOTFs5Dw"
        data-category="Announcements"
        data-category-id="DIC_kwDOTFs5D84DAFns"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="en"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  </article>
</BaseLayout>
