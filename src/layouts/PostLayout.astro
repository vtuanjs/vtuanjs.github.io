---
import BaseLayout from './BaseLayout.astro';
import type { SpaceId } from '../consts';
import { spaceMeta, formatDate, UI } from '../lib/site';

interface PostLink {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  image?: string;
  space: SpaceId;
  tags?: string[];
  prev?: PostLink;
  next?: PostLink;
}
const { title, description, date, author, image, space, tags = [], prev, next } = Astro.props;
const info = spaceMeta(space);
const t = UI;
---
<BaseLayout
  title={title}
  description={description}
  image={image}
  type="article"
  publishedDate={date}
>
  <article class="post">
    <p class="post-space"><a href={info.path}>{info.name}</a></p>
    <h1 class="post-title">{title}</h1>
    <p class="post-meta">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
      {author && <> · {author}</>}
    </p>
    {tags.length > 0 && (
      <div class="tag-list">
        {tags.map((tag) => (
          <a class="tag" href={`${info.path}tags/${tag}/`}>{tag}</a>
        ))}
      </div>
    )}
    <div class="post-content">
      <slot />
    </div>
    {(prev || next) && (
      <nav class="post-nav" aria-label="Post navigation">
        {prev ? (
          <a class="post-nav-link prev" href={prev.href}>
            <span class="post-nav-label">{t.prevPost}</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a class="post-nav-link next" href={next.href}>
            <span class="post-nav-label">{t.nextPost}</span>
            <span class="post-nav-title">{next.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}
    <div class="post-comments">
      <script src="https://giscus.app/client.js"
        data-repo="vtuanjs/vtuanjs.github.io"
        data-repo-id="R_kgDOTFs5Dw"
        data-category="Announcements"
        data-category-id="DIC_kwDOTFs5D84DAFns"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async>
      </script>
    </div>
  </article>
</BaseLayout>
