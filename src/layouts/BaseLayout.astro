---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { langFromPath } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  // Counterpart URL in the other language, forwarded to the Header toggle.
  altUrl?: string;
  // When true, the counterpart is a fallback (no real translation) — the
  // toggle asks the reader to confirm before navigating.
  altConfirm?: boolean;
}
const { altUrl, altConfirm, ...headProps } = Astro.props;
const lang = langFromPath(Astro.url.pathname);
---
<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead {...headProps} />
  </head>
  <body>
    <Header altUrl={altUrl} altConfirm={altConfirm} />
    <main class="site-main">
      <slot />
    </main>
    <Footer />

    <script>
      // Render any ```mermaid diagrams. Mermaid is heavy, so we only load it
      // when a page actually contains a diagram (dynamic import => its own chunk).
      const blocks = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
      if (blocks.length) {
        const { default: mermaid } = await import('mermaid');
        // Cache the raw source so we can re-render when the theme changes.
        blocks.forEach((el) => { el.dataset.src = el.textContent || ''; });

        const renderAll = async () => {
          const dark = document.documentElement.getAttribute('data-theme') === 'dark';
          mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'default', securityLevel: 'strict' });
          blocks.forEach((el) => {
            el.removeAttribute('data-processed');
            el.textContent = el.dataset.src || '';
          });
          await mermaid.run({ nodes: blocks });
        };

        await renderAll();

        // Re-draw with matching colors when the dark/light toggle flips.
        new MutationObserver((muts) => {
          if (muts.some((m) => m.attributeName === 'data-theme')) renderAll();
        }).observe(document.documentElement, { attributes: true });
      }
    </script>

    <button id="scroll-top" aria-label="Scroll to top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>

    <script>
      const btn = document.getElementById('scroll-top');
      const toggle = () => btn?.classList.toggle('visible', window.scrollY > 300);
      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
    </script>

    <style is:global>
      #scroll-top {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 50%;
        border: 1px solid var(--line);
        background: var(--bg);
        color: var(--ink);
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
      }
      #scroll-top.visible {
        opacity: 1;
        pointer-events: auto;
      }
      #scroll-top:hover { transform: translateY(-2px); }

      pre.mermaid {
        background: none;
        padding: 0;
        text-align: center;
        overflow-x: auto;
      }
      pre.mermaid:not([data-processed]) { visibility: hidden; }
      pre.mermaid svg { max-width: 100%; height: auto; }
    </style>
  </body>
</html>
