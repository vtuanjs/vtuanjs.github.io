---
// The about page, rendered for either language. /about.astro and
// /vi/about.astro are thin wrappers that just pick the `lang`.
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactList from './ContactList.astro';
import { UI, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = UI[lang].about;
// The "what I do" body reuses the home page's lead paragraphs verbatim.
const body = UI[lang].home.lead;
---
<BaseLayout title={t.title} description={t.description}>
  <article class="post">
    <h1 class="post-title">{t.title}</h1>
    <div class="post-content">
      <p set:html={t.introHtml}></p>
      <ul>
        {t.flavours.map((f) => <li set:html={f}></li>)}
      </ul>

      <h2>{t.whatIDo}</h2>
      {body.map((p) => <p>{p}</p>)}

      <h2>{t.getInTouch}</h2>
      <ContactList />
    </div>
  </article>
</BaseLayout>
