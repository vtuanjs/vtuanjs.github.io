---
// The about page.
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactList from './ContactList.astro';
import { UI } from '../lib/site';

const t = UI.about;
// The "what I do" body reuses the home page's lead paragraphs verbatim.
const body = UI.home.lead;
---
<BaseLayout title={t.title} description={t.description}>
  <article class="post">
    <h1 class="post-title">{t.title}</h1>
    <div class="post-content">
      <p set:html={t.introHtml}></p>
      <ul>
        {t.flavours.map((f) => <li set:html={f}></li>)}
      </ul>

      <h2>{t.whatIDo}</h2>
      {body.map((p) => <p>{p}</p>)}

      <h2>{t.getInTouch}</h2>
      <ContactList />
    </div>
  </article>
</BaseLayout>
