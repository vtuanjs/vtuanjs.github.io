---
// The landing page.
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactList from './ContactList.astro';
import { SITE, SPACE_IDS } from '../consts';
import { spaceMeta, formatDate, UI } from '../lib/site';
import { loadPosts } from '../lib/posts';

const t = UI.home;

const spaces = SPACE_IDS.map((id) => spaceMeta(id));
const recent = await Promise.all(
  SPACE_IDS.map(async (id) => {
    const meta = spaceMeta(id);
    return { label: meta.label, path: meta.path, posts: (await loadPosts(id)).slice(0, 3) };
  })
);
---
<BaseLayout title={SITE.title} description={t.description}>
  <section class="hero">
    <h1>{t.greeting}</h1>
    {t.lead.map((p) => <p class="lead">{p}</p>)}
    <ContactList />
  </section>

  <section class="spaces">
    {spaces.map((s) => (
      <a class="space-card" href={s.path}>
        <h2>{s.name}</h2>
        <p>{s.blurb}</p>
      </a>
    ))}
  </section>

  <section class="recent">
    {recent.map((r) => (
      <>
        <h2>{t.latestFrom} {r.label}</h2>
        <ul class="post-list">
          {r.posts.map((p) => (
            <li>
              <a href={`${r.path}${p.id}/`}>{p.data.title}</a>
              <span class="date">{formatDate(p.data.date, 'short')}</span>
            </li>
          ))}
        </ul>
      </>
    ))}
  </section>
</BaseLayout>
