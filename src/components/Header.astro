---
import { SITE, NAV } from '../consts';
const path = Astro.url.pathname;
---
<header class="site-header">
  <a class="site-title" href="/">{SITE.title}</a>
  <nav class="site-nav">
    {NAV.map((item) => (
      <a
        href={item.href}
        aria-current={path.startsWith(item.href) ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>
</header>
