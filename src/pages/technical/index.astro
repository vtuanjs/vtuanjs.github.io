---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { SPACES } from '../../consts';

const posts = (await getCollection('technical'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={SPACES.technical.name} description={SPACES.technical.blurb}>
  <h1>{SPACES.technical.name}</h1>
  <p class="lead">{SPACES.technical.blurb} <a href="/technical/rss.xml">RSS</a></p>
  <PostList posts={posts} basePath="/technical/" />
</BaseLayout>
