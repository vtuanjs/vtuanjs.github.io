---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { SPACES } from '../../consts';

const posts = (await getCollection('ai'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={SPACES.ai.name} description={SPACES.ai.blurb}>
  <h1>{SPACES.ai.name}</h1>
  <p class="lead">{SPACES.ai.blurb} <a href="/ai/rss.xml">RSS</a></p>
  <PostList posts={posts} basePath="/ai/" />
</BaseLayout>
