---
import { render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { SPACE_IDS, type SpaceId } from '../../../consts';
import { spaceMeta, stripVi } from '../../../lib/i18n';
import { getAdjacentPosts, loadPosts } from '../../../lib/posts';

export async function getStaticPaths() {
  const paths = [];
  for (const space of SPACE_IDS) {
    for (const post of await loadPosts(space, 'vi', { drafts: true })) {
      paths.push({ params: { space, slug: stripVi(post.id) }, props: { post } });
    }
  }
  return paths;
}

const { post } = Astro.props;
const space = Astro.params.space as SpaceId;
const { Content } = await render(post);

const base = spaceMeta(space, 'vi').path;
const { newer, older } = await getAdjacentPosts(space, 'vi', post.id);
const toLink = (p: typeof newer) =>
  p ? { title: p.data.title, href: `${base}${stripVi(p.id)}/` } : undefined;
---
<PostLayout {...post.data} space={space} lang="vi" prev={toLink(older)} next={toLink(newer)}>
  <Content />
</PostLayout>
