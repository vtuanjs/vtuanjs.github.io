---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SPACES, SOCIALS } from '../consts';

const byDateDesc = (a: { data: { date: Date; }; }, b: { data: { date: Date; }; }) => b.data.date.valueOf() - a.data.date.valueOf();
const notDraft = (p: { data: { draft: any; }; }) => !p.data.draft;

const product = (await getCollection('product')).filter(notDraft).sort(byDateDesc);
const technical = (await getCollection('technical')).filter(notDraft).sort(byDateDesc);
const ai = (await getCollection('ai')).filter(notDraft).sort(byDateDesc);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="hero">
    <h1>Hi, I'm Tuan</h1>
    <p class="lead">
      I'm a software engineer who enjoys turning fuzzy problems into systems
      that are simple to reason about. I care about clean architecture,
      pragmatic trade-offs, and shipping things that actually help the people
      using them.
    </p>
    <p class="lead">
      This blog is where I think out loud — half about how products get built
      and why, half about the engineering details that make them work.
    </p>
    <ul class="contact-list">
      <li>Email: <a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      {SOCIALS.map((s) => (
        <li>{s.label}: <a href={s.href} rel="me">{s.href.replace(/^https?:\/\//, '')}</a></li>
      ))}
    </ul>
  </section>

  <section class="spaces">
    <a class="space-card" href={SPACES.product.path}>
      <h2>{SPACES.product.name}</h2>
      <p>{SPACES.product.blurb}</p>
    </a>
    <a class="space-card" href={SPACES.technical.path}>
      <h2>{SPACES.technical.name}</h2>
      <p>{SPACES.technical.blurb}</p>
    </a>
    <a class="space-card" href={SPACES.ai.path}>
      <h2>{SPACES.ai.name}</h2>
      <p>{SPACES.ai.blurb}</p>
    </a>
  </section>

  <section class="recent">
    <h2>Latest from Product</h2>
    <ul class="post-list">
      {product.slice(0, 3).map((p) => (
        <li>
          <a href={`/product/${p.id}/`}>{p.data.title}</a>
          <span class="date">{fmt(p.data.date)}</span>
        </li>
      ))}
    </ul>

    <h2>Latest from Technical</h2>
    <ul class="post-list">
      {technical.slice(0, 3).map((p) => (
        <li>
          <a href={`/technical/${p.id}/`}>{p.data.title}</a>
          <span class="date">{fmt(p.data.date)}</span>
        </li>
      ))}
    </ul>

    <h2>Latest from AI</h2>
    <ul class="post-list">
      {ai.slice(0, 3).map((p) => (
        <li>
          <a href={`/ai/${p.id}/`}>{p.data.title}</a>
          <span class="date">{fmt(p.data.date)}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .contact-list {
    list-style: none;
    padding: 0;
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
