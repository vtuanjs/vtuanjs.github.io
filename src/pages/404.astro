---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Page not found">
  <section style="text-align: center; padding: 4rem 1rem;">
    <h1>404</h1>
    <p>Sorry, this page doesn't exist.</p>
    <a href="/" style="display: inline-block; margin-top: 1.5rem; padding: 0.6rem 1.4rem; background: var(--color-accent, #0070f3); color: #fff; border-radius: 6px; text-decoration: none; font-weight: 500;">
      Back to home
    </a>
  </section>
</BaseLayout>
